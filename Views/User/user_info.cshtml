@model App.Models.UserLotsViewModel

<div class="content-container">
    <div class="user-info">
        <p>Логин: @Model.user.login</p>
        <p>Почта: @Model.user.email</p>
    </div>

    <a href="/lots/my/create" class="button">Создать лот</a>

    <div class="user-lots">
        <h2>Мои лоты</h2>
        @if (Model.lots.Count == 0) {
            <p>У вас пока нет лотов.</p>
        } else {
            <div class="user-lot-list">
                @foreach (var lot in Model.lots) {
                    <div class="user-lot-item" id="lot-@lot.id">
                        <div class="user-lot-thumb">
                            <img src="@(lot.thumbnail_path ?? "/images/no-image.png")" alt="" />
                        </div>
                        <div class="user-lot-info">
                            <a href="/lots/@lot.id">@lot.title</a>
                            <span class="lot-price">@lot.current_price</span>
                        </div>
                        <div class="user-lot-actions">
                            <button class="delete-btn"
                                    hx-delete="/lots/my/@lot.id"
                                    hx-target="#lot-@lot.id"
                                    hx-swap="outerHTML"
                                    hx-confirm="Удалить лот?">
                                Удалить
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
